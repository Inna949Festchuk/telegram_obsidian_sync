# =============================================================================
# Telegram to Obsidian Converter - Конфигурация
# =============================================================================

# -----------------------------------------------------------------------------
# 📁 ПУТИ К ФАЙЛАМ
# -----------------------------------------------------------------------------

# Путь к JSON файлу экспорта Telegram
TELEGRAM_JSON_FILE="/home/konstantin/Загрузки/Telegram Desktop/DataExport_2026-03-30/result.json"

# Корневая папка, где лежат медиафайлы и HTML
TELEGRAM_EXPORT_BASE="/home/konstantin/Загрузки/Telegram Desktop/DataExport_2026-03-30"

# Папка для сохранения заметок Obsidian
OBSIDIAN_OUTPUT_DIR="/home/konstantin/Документы/ObsidianData/ObsidianData"

# Папка для скрипта (где будет создан patch.txt)
SCRIPT_DIR="/home/konstantin/Документы/telegram_obsidian_sync"

# Путь к файлу patch.txt (будет сгенерирован автоматически)
PATCH_FILE="/home/konstantin/Документы/telegram_obsidian_sync/patch.txt"

# -----------------------------------------------------------------------------
# 🔄 АВТОМАТИЧЕСКАЯ ГЕНЕРАЦИЯ PATCH.TXT
# -----------------------------------------------------------------------------

# Генерировать patch.txt автоматически при запуске
# Генерация patch.txt
# ls -R "/home/konstantin/Загрузки/Telegram Desktop/DataExport_2026-03-26" > "/home/konstantin/Документы/telegram_obsidian_sync/patch.txt"
GENERATE_PATCH_FILE=true

# -----------------------------------------------------------------------------
# 🖼️  НАСТРОЙКИ МЕДИА
# -----------------------------------------------------------------------------

# Копировать ли медиафайлы (фото, видео, документы)
COPY_MEDIA=true

# Копировать ли аватарки профилей
COPY_PROFILE_PICS=true

# -----------------------------------------------------------------------------
# 📄 НАСТРОЙКИ КОНТЕНТА
# -----------------------------------------------------------------------------

# Создавать ли индексный файл со списком всех чатов
CREATE_INDEX=true

# Создавать ли отдельные заметки для контактов
CREATE_CONTACTS=true

# Добавлять ли frontmatter (метаданные YAML) к заметкам
CREATE_FRONTMATTER=true

# Преобразовывать ли спойлеры в callout Obsidian
SPOILER_AS_CALLOUT=true

# -----------------------------------------------------------------------------
# 📅 ОПТИМИЗАЦИЯ
# -----------------------------------------------------------------------------

# Группировать сообщения по дням (рекомендуется для больших экспортов)
GROUP_BY_DAY=true

# Минимальное количество сообщений для создания файла дня
MIN_MESSAGES_PER_DAY=1

# =============================================================================

# Токен бота от @BotFather
BOTPHAZER_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Ссылки на проект
GITHUB_URL=https://github.com/yourusername/telegram-to-obsidian
README_URL=https://github.com/yourusername/telegram-to-obsidian/blob/main/README.md

# ID администратора (ваш Telegram user ID)
# Узнать можно через бота @userinfobot
ADMIN_ID=123456789